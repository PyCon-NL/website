{
	"name": "pycon-nl.org",
	"version": "1.10.3",
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"postbuild": "svelte-sitemap --domain https://pycon-nl.org",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check .",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.64.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tsconfig/svelte": "^5.0.8",
		"@types/lodash-es": "^4.17.12",
		"autoprefixer": "^10.5.0",
		"lodash-es": "^4.18.1",
		"postcss": "^8.5.15",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"prettier-plugin-tailwindcss": "^0.6.5",
		"svelte": "^5.56.3",
		"svelte-awesome": "^3.3.5",
		"svelte-check": "^4.6.0",
		"svelte-fast-marquee": "^1.1.2",
		"svelte-preprocess": "^6.0.5",
		"svelte-sitemap": "^3.2.0",
		"tailwindcss": "^3.4.19",
		"tslib": "^2.8.1",
		"typescript": "^5.6.2",
		"vite": "^8.0.16"
	},
	"type": "module",
	"dependencies": {
		"marked": "^18.0.5",
		"marked-smartypants": "^1.1.12"
	},
	"overrides": {
		"cookie": "^0.7.0"
	},
	"allowScripts": {
		"fsevents@2.3.3": true,
		"svelte-preprocess@6.0.5": true
	}
}
